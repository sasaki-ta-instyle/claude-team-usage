# Database (Neon Postgres)
DATABASE_URL=postgres://user:pass@host/dbname?sslmode=require

# Auth.js v5 (Credentials provider, shared admin password)
AUTH_SECRET=
# Auth.js v5 は AUTH_URL の pathname を auth basePath として扱う。
# Next.js basePath (/claude-team-usage) + auth basePath (/api/auth) の合成形を渡す。
AUTH_URL=http://localhost:3000/claude-team-usage/api/auth
AUTH_TRUST_HOST=true

# Shared admin password (bcrypt hash).
# Use: node -e "console.log(require('bcryptjs').hashSync(process.argv[1], 12))" 'your-password'
# 重要: .env ファイルに書く際は $ を必ず \$ にエスケープすること（dotenv-expand が $2a を変数展開して hash を壊す）
ADMIN_PASSWORD_HASH=

# Anthropic Admin API
ANTHROPIC_ADMIN_API_KEY=sk-ant-admin01-...

# Sync endpoint bearer token (random secret used by cron)
SYNC_TOKEN=

# JPY conversion rate (used for display only)
JPY_PER_USD=155
